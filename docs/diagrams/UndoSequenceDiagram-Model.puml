@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
participant ":AddressBook" as AddressBook MODEL_COLOR
end box

[-> Model : canUndo()
activate Model
Model -->[ : true
deactivate Model

[-> Model : undoLastChange()
activate Model

Model -> AddressBook : resetData(previousAddressBook)
activate AddressBook
AddressBook --> Model
deactivate AddressBook

Model -> Model : updateFilteredCatList(PREDICATE_SHOW_ALL_CATS)
Model -> Model : previousAddressBook = null\nhasUndoableState = false

[<-- Model
deactivate Model

@enduml
