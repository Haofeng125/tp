<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
      <ColumnConstraints hgrow="NEVER" minWidth="90" prefWidth="90" maxWidth="90" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="8" right="5" bottom="8" left="14" />
      </padding>
      <!-- Index + Name row -->
      <HBox spacing="2" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_index_label">
          <minWidth>
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      </HBox>
      <!-- Traits pills -->
      <FlowPane fx:id="traits" id="tags">
        <padding>
          <Insets top="4" bottom="2" />
        </padding>
      </FlowPane>
      <!-- Location -->
      <Label fx:id="catLocation" styleClass="cell_small_label" />
      <!-- Health -->
      <Label fx:id="health" styleClass="cell_small_label" />
    </VBox>
    <ImageView fx:id="catImage" fitWidth="72" fitHeight="72" preserveRatio="true"
               GridPane.columnIndex="1" GridPane.valignment="CENTER">
      <GridPane.margin>
        <Insets top="5" right="8" bottom="5" left="5" />
      </GridPane.margin>
    </ImageView>
  </GridPane>
</HBox>
